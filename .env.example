# PPT Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================================
# 必需
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=pptagent_local

# API Key加密主密钥（生成方式：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
MASTER_ENCRYPTION_KEY=

# JWT认证密钥（生产环境必须更换，推荐32+字符随机字符串）
JWT_SECRET=

# ============================================================
# 可选 — 性能与限流
# ============================================================

# 单用户最大并发生成任务数（默认2）
MAX_CONCURRENT_PER_USER=2

# 系统全局最大并发任务数（默认5）
MAX_CONCURRENT_TASKS=5

# ============================================================
# 可选 — 渲染
# ============================================================

# 渲染模式：html（默认，需Node.js）或 legacy（纯python-pptx）
RENDER_MODE=html

# Node.js渲染服务器端口（默认19876）
RENDER_PORT=19876

# Chromium回收：每N页重启浏览器（默认50）
CHROMIUM_RECYCLE_PAGES=50

# Chromium回收：每N秒重启浏览器（默认1800）
CHROMIUM_RECYCLE_SECONDS=1800

# ============================================================
# 可选 — 安全
# ============================================================

# CORS允许的前端域名（逗号分隔，默认 http://localhost:3000）
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# 可选 — LLM
# ============================================================

# LLM API Key（也可在界面配置，此处仅作为默认值）
GLM_API_KEY=
